        "\"\"\"\n",
        "IMPROVED TARGET DEFINITION FOR ANTIMICROBIAL SCORE\n",
        "Includes physics-based validation and proper data handling\n",
        "\"\"\"\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.preprocessing import RobustScaler\n",
        "from scipy.stats import pearsonr\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "print(\"=\"*80)\n",
        "print(\"IMPROVED ANTIMICROBIAL SCORE CALCULATION\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# ============================================================\n",
        "# 1. LOAD DATA\n",
        "# ============================================================\n",
        "\n",
        "CLEAN_PATH = \"/content/data_cleaned_v1.csv\"\n",
        "df = pd.read_csv(CLEAN_PATH)\n",
        "print(f\"\\n✓ Loaded data: {df.shape}\")\n",
        "\n",
        "# ============================================================\n",
        "# 2. VALIDATE REQUIRED COLUMNS\n",
        "# ============================================================\n",
        "\n",
        "required_cols = [\"Particle_Size_nm\", \"PDI\", \"Zeta_Potential_mV\"]\n",
        "missing = [c for c in required_cols if c not in df.columns]\n",
        "if missing:\n",
        "    raise ValueError(f\"❌ Missing required columns: {missing}\")\n",
        "\n",
        "print(\"✓ All required physicochemical properties present\")\n",
        "\n",
        "# ============================================================\n",
        "# 3. DATA QUALITY CHECKS\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"DATA QUALITY CHECKS\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# Check for missing values\n",
        "missing_counts = df[required_cols].isnull().sum()\n",
        "if missing_counts.any():\n",
        "    print(\"⚠️  Missing values detected:\")\n",
        "    print(missing_counts[missing_counts > 0])\n",
        "    df = df.dropna(subset=required_cols)\n",
        "    print(f\"✓ Dropped rows with missing values. New shape: {df.shape}\")\n",
        "\n",
        "# Check for outliers (physics-based bounds)\n",
        "outliers = []\n",
        "\n",
        "# Particle size: typical range 10-200 nm\n",
        "size_outliers = ((df[\"Particle_Size_nm\"] < 10) | (df[\"Particle_Size_nm\"] > 200)).sum()\n",
        "if size_outliers > 0:\n",
        "    print(f\"⚠️  {size_outliers} particle size outliers (<10 or >200 nm)\")\n",
        "    outliers.append(f\"Size: {size_outliers}\")\n",
        "\n",
        "# PDI: should be 0-1 (typically <0.5 for good samples)\n",
        "pdi_outliers = ((df[\"PDI\"] < 0) | (df[\"PDI\"] > 1)).sum()\n",
        "if pdi_outliers > 0:\n",
        "    print(f\"⚠️  {pdi_outliers} PDI outliers (<0 or >1)\")\n",
        "    outliers.append(f\"PDI: {pdi_outliers}\")\n",
        "\n",
        "# Zeta: typical range -100 to +100 mV\n",
        "zeta_outliers = (np.abs(df[\"Zeta_Potential_mV\"]) > 100).sum()\n",
        "if zeta_outliers > 0:\n",
        "    print(f\"⚠️  {zeta_outliers} zeta potential outliers (|zeta| > 100 mV)\")\n",
        "    outliers.append(f\"Zeta: {zeta_outliers}\")\n",
        "\n",
        "if not outliers:\n",
        "    print(\"✓ No outliers detected - data looks physically reasonable\")\n",
        "\n",
        "# ============================================================\n",
        "# 4. PHYSICS-BASED SCORE COMPONENTS\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"CALCULATING PHYSICS-BASED SCORE COMPONENTS\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# Component 1: PARTICLE SIZE SCORE\n",
        "# Literature: 20-50 nm optimal for antimicrobial activity\n",
        "# Smaller = better penetration, but too small (<15 nm) = less stable\n",
        "def size_score(size):\n",
        "    \"\"\"\n",
        "    Score based on literature-optimal size range\n",
        "    Peak at 25-35 nm, decay outside this range\n",
        "    \"\"\"\n",
        "    if size < 15:\n",
        "        return 0.5  # Too small - stability issues\n",
        "    elif 15 <= size <= 50:\n",
        "        # Linear increase from 15 to 25, then linear decrease to 50\n",
        "        if size <= 25:\n",
        "            return 0.5 + 0.5 * (size - 15) / 10  # 0.5 → 1.0\n",
        "        else:\n",
        "            return 1.0 - 0.5 * (size - 25) / 25  # 1.0 → 0.5\n",
        "    else:\n",
        "        # Exponential decay for large particles\n",
        "        return 0.5 * np.exp(-0.02 * (size - 50))\n",
        "\n",
        "df[\"size_score\"] = df[\"Particle_Size_nm\"].apply(size_score)\n",
        "\n",
        "# Component 2: PDI SCORE\n",
        "# Literature: PDI < 0.3 excellent, 0.3-0.5 good, >0.5 poor\n",
        "def pdi_score(pdi):\n",
        "    \"\"\"\n",
        "    Lower PDI = more monodisperse = better\n",
        "    \"\"\"\n",
        "    if pdi < 0.3:\n",
        "        return 1.0  # Excellent\n",
        "    elif pdi < 0.5:\n",
        "        return 1.0 - (pdi - 0.3) / 0.2  # Linear decay 1.0 → 0.0\n",
        "    else:\n",
        "        return 0.0  # Poor quality\n",
        "\n",
        "df[\"pdi_score\"] = df[\"PDI\"].apply(pdi_score)\n",
        "\n",
        "# Component 3: ZETA POTENTIAL SCORE\n",
        "# Literature: |zeta| > 30 mV stable, 20-30 mV moderate, <20 mV unstable\n",
        "# For antimicrobial: positive charge often better (electrostatic interaction)\n",
        "def zeta_score(zeta):\n",
        "    \"\"\"\n",
        "    Stability score based on magnitude\n",
        "    Bonus for positive charge (cationic = better bacterial adhesion)\n",
        "    \"\"\"\n",
        "    abs_zeta = np.abs(zeta)\n",
        "\n",
        "    # Stability component (based on magnitude)\n",
        "    if abs_zeta > 30:\n",
        "        stability = 1.0  # Highly stable\n",
        "    elif abs_zeta > 20:\n",
        "        stability = 0.5 + 0.5 * (abs_zeta - 20) / 10  # 0.5 → 1.0\n",
        "    else:\n",
        "        stability = abs_zeta / 20  # Linear 0 → 0.5\n",
        "\n",
        "    # Charge preference (positive is generally better for antimicrobial)\n",
        "    if zeta > 0:\n",
        "        charge_bonus = 0.1  # 10% bonus for cationic\n",
        "    else:\n",
        "        charge_bonus = 0.0\n",
        "\n",
        "    return min(stability + charge_bonus, 1.0)  # Cap at 1.0\n",
        "\n",
        "df[\"zeta_score\"] = df[\"Zeta_Potential_mV\"].apply(zeta_score)\n",
        "\n",
        "# ============================================================\n",
        "# 5. LITERATURE-INFORMED WEIGHTED COMPOSITE SCORE\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"COMPOSITE ANTIMICROBIAL SCORE\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# Weights based on literature importance:\n",
        "# - Size: Most critical (40%) - determines penetration and uptake\n",
        "# - Zeta: Important (35%) - affects stability and bacterial interaction\n",
        "# - PDI: Moderate (25%) - quality indicator but less direct impact\n",
        "\n",
        "WEIGHT_SIZE = 0.40\n",
        "WEIGHT_ZETA = 0.35\n",
        "WEIGHT_PDI = 0.25\n",
        "\n",
        "df[\"Antimicrobial_Score\"] = (\n",
        "    WEIGHT_SIZE * df[\"size_score\"] +\n",
        "    WEIGHT_ZETA * df[\"zeta_score\"] +\n",
        "    WEIGHT_PDI * df[\"pdi_score\"]\n",
        ")\n",
        "\n",
        "print(f\"\\nWeights used:\")\n",
        "print(f\"  - Particle Size: {WEIGHT_SIZE:.0%}\")\n",
        "print(f\"  - Zeta Potential: {WEIGHT_ZETA:.0%}\")\n",
        "print(f\"  - PDI: {WEIGHT_PDI:.0%}\")\n",
        "\n",
        "print(f\"\\n✓ Antimicrobial Score calculated:\")\n",
        "print(f\"  - Range: {df['Antimicrobial_Score'].min():.3f} to {df['Antimicrobial_Score'].max():.3f}\")\n",
        "print(f\"  - Mean: {df['Antimicrobial_Score'].mean():.3f} ± {df['Antimicrobial_Score'].std():.3f}\")\n",
        "print(f\"  - Median: {df['Antimicrobial_Score'].median():.3f}\")\n",
        "\n",
        "# ============================================================\n",
        "# 6. VALIDATION: PHYSICS-BASED SANITY CHECKS\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"PHYSICS-BASED VALIDATION\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# Check 1: Smaller particles should generally score higher\n",
        "size_corr, size_p = pearsonr(df[\"Particle_Size_nm\"], df[\"Antimicrobial_Score\"])\n",
        "print(f\"\\n1. Size vs Score correlation: {size_corr:.3f} (p={size_p:.4f})\")\n",
        "if size_corr < -0.3:\n",
        "    print(\"   ✓ Expected negative correlation (smaller = better)\")\n",
        "elif size_corr > 0.3:\n",
        "    print(\"   ⚠️  Unexpected positive correlation - check logic!\")\n",
        "else:\n",
        "    print(\"   ⚠️  Weak correlation - size may not be driving factor\")\n",
        "\n",
        "# Check 2: Higher |zeta| should correlate with score\n",
        "zeta_abs_corr, zeta_p = pearsonr(np.abs(df[\"Zeta_Potential_mV\"]), df[\"Antimicrobial_Score\"])\n",
        "print(f\"\\n2. |Zeta| vs Score correlation: {zeta_abs_corr:.3f} (p={zeta_p:.4f})\")\n",
        "if zeta_abs_corr > 0.3:\n",
        "    print(\"   ✓ Expected positive correlation (higher stability = better)\")\n",
        "else:\n",
        "    print(\"   ⚠️  Weak correlation - zeta may not be important\")\n",
        "\n",
        "# Check 3: Lower PDI should correlate with higher score\n",
        "pdi_corr, pdi_p = pearsonr(df[\"PDI\"], df[\"Antimicrobial_Score\"])\n",
        "print(f\"\\n3. PDI vs Score correlation: {pdi_corr:.3f} (p={pdi_p:.4f})\")\n",
        "if pdi_corr < -0.2:\n",
        "    print(\"   ✓ Expected negative correlation (lower PDI = better)\")\n",
        "else:\n",
        "    print(\"   ⚠️  Weak/positive correlation - check if PDI matters\")\n",
        "\n",
        "# Check 4: Identify best and worst samples\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"BEST vs WORST SAMPLES (Physics Check)\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "top_5 = df.nlargest(5, \"Antimicrobial_Score\")[[\"Particle_Size_nm\", \"PDI\", \"Zeta_Potential_mV\", \"Antimicrobial_Score\"]]\n",
        "bottom_5 = df.nsmallest(5, \"Antimicrobial_Score\")[[\"Particle_Size_nm\", \"PDI\", \"Zeta_Potential_mV\", \"Antimicrobial_Score\"]]\n",
        "\n",
        "print(\"\\nTOP 5 Samples (Highest Score):\")\n",
