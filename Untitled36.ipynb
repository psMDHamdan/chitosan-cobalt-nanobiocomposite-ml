      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import joblib\n",
        "from scipy.optimize import differential_evolution\n",
        "from sklearn.ensemble import GradientBoostingRegressor\n",
        "from sklearn.multioutput import MultiOutputRegressor\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.impute import KNNImputer\n",
        "import warnings\n",
        "\n",
        "# Suppress warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "print(\"=\"*100)\n",
        "print(\"💎 VIRTUAL CHEMIST: INTEGRATED HIGH-YIELD OPTIMIZATION\")\n",
        "print(\"=\"*100)\n",
        "\n",
        "# ==============================================================================\n",
        "# 1. LOAD YOUR \"GOLD STANDARD\" BIO-MODEL\n",
        "# ==============================================================================\n",
        "try:\n",
        "    # Loading the artifacts saved by your training script\n",
        "    bio_model = joblib.load(\"best_model_corrected.joblib\")\n",
        "    bio_scaler = joblib.load(\"feature_scaler.joblib\")\n",
        "    feature_cols = joblib.load(\"feature_columns.pkl\")\n",
        "    print(f\"✓ Loaded Bio-Activity Model: {type(bio_model).__name__}\")\n",
        "    print(f\"✓ Loaded Scaler: {type(bio_scaler).__name__}\")\n",
        "    print(f\"✓ Feature Columns: {len(feature_cols)} features loaded\")\n",
        "except FileNotFoundError as e:\n",
        "    print(f\"❌ ERROR: Could not load model files. ({e})\")\n",
        "    print(\"   Please run your Training Script first to generate .joblib files.\")\n",
        "    exit()\n",
        "\n",
        "# ==============================================================================\n",
        "# 2. TRAIN PHYSICS ENGINE (Stability Monitor)\n",
        "# ==============================================================================\n",
        "# Your training code predicted \"Score\", but we also need to predict \"Size\" & \"Zeta\"\n",
        "# to ensure we don't make unstable particles. We train a quick helper model here.\n",
        "\n",
        "print(\"\\n   Initializing Physics Engine (Size/Zeta Predictor)...\")\n",
        "try:\n",
        "    df = pd.read_csv(\"data_cc_v3.csv\")\n",
        "\n",
        "    # 1. Clean Data\n",
        "    def clean_val(x):\n",
        "        try: return float(str(x).replace('O','0').replace(',','.'))\n",
        "        except: return np.nan\n",
        "\n",
        "    for c in [\"Chitosan_Conc_mgmL\", \"Cobalt_Conc_mM\", \"pH\", \"Temperature_C\", \"Time_hr\", \"Particle_Size_nm\", \"Zeta_Potential_mV\"]:\n",
        "        if c in df.columns: df[c] = df[c].apply(clean_val)\n",
        "\n",
        "    df_clean = df.dropna(subset=[\"Particle_Size_nm\", \"Zeta_Potential_mV\"])\n",
