        "# ============================================================\n",
        "# STEP 1 — Data Loading & Rigorous Cleaning (CORRECTED)\n",
        "# ============================================================\n",
        "\n",
        "import re\n",
        "import math\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.impute import KNNImputer\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ---------- CONFIG ----------\n",
        "RAW_PATH   = \"data_cc_v3.csv\"      # Ensure this matches your uploaded file name\n",
        "SAVE_PATH  = \"data_cleaned_v1.csv\"\n",
        "EXPECTED_N = 93\n",
        "PKA_CHITOSAN = 6.3\n",
        "\n",
        "# ---------- 1) LOAD ----------\n",
        "df = pd.read_csv(RAW_PATH)\n",
        "initial_n = df.shape[0]\n",
        "print(f\"[Load] shape = {df.shape}\")\n",
        "\n",
        "# ---------- 2) REMOVE paper_id COLUMNS ----------\n",
        "id_like = [c for c in df.columns if re.search(r'\\b(paper_?id|^id$)\\b', c, flags=re.I)]\n",
        "if id_like:\n",
        "    print(f\"[ID] Removing columns: {id_like}\")\n",
        "    df = df.drop(columns=id_like)\n",
        "\n",
        "# ---------- 3) COERCE TEXT → NUMERIC (safe) ----------\n",
        "num_cols_expected = [\n",
        "    \"Chitosan_Conc_mgmL\", \"Chitosan_MW_kDa\", \"Chitosan_DD_percent\",\n",
        "    \"Cobalt_Conc_mM\", \"pH\", \"Temperature_C\", \"Time_hr\",\n",
        "    \"Stirring_Speed_rpm\", \"Crosslinker_Conc_mM\", \"Ionic_Strength_mM\",\n",
        "    \"Particle_Size_nm\", \"Size_SD_nm\", \"PDI\", \"Zeta_Potential_mV\"\n",
        "]\n",
        "\n",
        "def to_num(x):\n",
        "    if pd.isna(x): return np.nan\n",
        "    s = str(x).strip()\n",
        "    # fix common OCR issues\n",
        "    s = s.replace('O','0').replace('l','1')\n",
        "    s = s.replace(',', '.')\n",
        "    # remove stray units (retain digits, dots, minus, e/E for notation)\n",
        "    s = re.sub(r'[^\\d\\.\\-eE]+', '', s)\n",
        "    try:\n",
        "        return float(s)\n",
        "    except:\n",
        "        return np.nan\n",
        "\n",
        "for c in num_cols_expected:\n",
        "    if c in df.columns:\n",
        "        df[c] = df[c].apply(to_num)\n",
        "\n",
        "# ---------- 4) SOLVENT POLARITY MAPPING (MOVED UP) ----------\n",
        "# We must do this BEFORE Label Encoding converts solvents to numbers!\n",
        "POLARITY = {\n",
        "    \"water\": 9.0, \"ethanol\": 5.2, \"methanol\": 5.1, \"isopropanol\": 4.3,\n",
        "    \"acetone\": 5.1, \"acetonitrile\": 5.8, \"dmf\": 6.4, \"dmso\": 7.2,\n",
        "    \"acetic acid\": 6.2, \"glycerol\": 6.5, \"na\": 0.0\n",
        "}\n",
        "\n",
        "def parse_solvent_to_polarity(s):\n",
        "    if s is None or (isinstance(s, float) and math.isnan(s)):\n",
        "        return 0.0\n",
        "    s = str(s).lower()\n",
        "    # Average polarity if mixed solvent\n",
        "    parts = re.split(r'[\\s,/+\\-]+', s)\n",
        "    vals = [POLARITY.get(p.strip(), np.nan) for p in parts if p.strip()]\n",
        "    vals = [v for v in vals if not pd.isna(v)]\n",
        "    if not vals:\n",
        "        return 0.0\n",
        "    return float(np.mean(vals))\n",
        "\n",
        "if \"Solvent\" in df.columns:\n",
        "    df[\"Solvent_polarity_index\"] = df[\"Solvent\"].apply(parse_solvent_to_polarity)\n",
        "else:\n",
        "    df[\"Solvent_polarity_index\"] = 0.0\n",
        "\n",
        "print(\"[Feature] Solvent Polarity Calculated.\")\n",
        "\n",
        "# ---------- 5) CLIP TO PHYSICAL BOUNDS ----------\n",
        "bounds = {\n",
        "    \"Chitosan_Conc_mgmL\":   (0.05, 50),\n",
        "    \"Chitosan_MW_kDa\":      (5, 1500),\n",
        "    \"Chitosan_DD_percent\":  (40, 100),\n",
        "    \"Cobalt_Conc_mM\":       (0.01, 300),\n",
        "    \"pH\":                   (1.0, 13.0),\n",
        "    \"Temperature_C\":        (15, 120),\n",
        "    \"Time_hr\":              (0.001, 24),\n",
        "    \"Stirring_Speed_rpm\":   (0, 2500),\n",
        "    \"Crosslinker_Conc_mM\":  (0, 100),\n",
        "    \"Ionic_Strength_mM\":    (0, 1000),\n",
        "    \"Particle_Size_nm\":     (3, 10000),\n",
        "    \"Size_SD_nm\":           (0, 5000),\n",
        "    \"PDI\":                  (0.0, 1.5),\n",
        "    \"Zeta_Potential_mV\":    (-120, 120),\n",
        "}\n",
        "\n",
        "for col,(lo,hi) in bounds.items():\n",
        "    if col in df.columns:\n",
        "        df[col] = df[col].clip(lower=lo, upper=hi)\n",
        "\n",
        "# ---------- 6) LABEL-ENCODE CATEGORICALS ----------\n",
        "cat_cols = [c for c in df.columns if df[c].dtype == 'object']\n",
        "encoders = {}\n",
        "for c in cat_cols:\n",
        "    df[c] = df[c].fillna(\"NA\").astype(str).str.strip().str.lower()\n",
        "    le = LabelEncoder()\n",
        "    df[c] = le.fit_transform(df[c])\n",
        "    encoders[c] = le\n",
        "if cat_cols:\n",
        "    print(f\"[Encode] Label-encoded categoricals: {cat_cols}\")\n",
        "\n",
        "# ---------- 7) KNN IMPUTATION (numeric only) ----------\n",
        "num_cols = [c for c in df.columns if pd.api.types.is_numeric_dtype(df[c])]\n",
        "imputer = KNNImputer(n_neighbors=5, weights='distance')\n",
        "df[num_cols] = imputer.fit_transform(df[num_cols])\n",
        "print(f\"[Impute] KNN complete on {len(num_cols)} numeric columns.\")\n",
        "\n",
        "# ---------- 8) FEATURE ENGINEERING (Ratios) ----------\n",
        "# Co:CS ratio\n",
        "if set([\"Cobalt_Conc_mM\",\"Chitosan_Conc_mgmL\"]).issubset(df.columns):\n",
        "    df[\"Co_to_CS_ratio\"] = df[\"Cobalt_Conc_mM\"] / (df[\"Chitosan_Conc_mgmL\"] + 1e-9)\n",
        "\n",
        "# Charge density proxy\n",
        "if set([\"Chitosan_DD_percent\",\"pH\"]).issubset(df.columns):\n",
        "    protonation = 1.0 / (1.0 + 10.0**(df[\"pH\"] - PKA_CHITOSAN))\n",
        "    df[\"CS_charge_index\"] = df[\"Chitosan_DD_percent\"] * protonation\n",
        "\n",
        "# pH - pKa difference\n",
        "if \"pH\" in df.columns:\n",
        "    df[\"pHpKa_diff\"] = df[\"pH\"] - PKA_CHITOSAN\n",
        "\n",
        "# Energy input proxy\n",
        "if set([\"Temperature_C\",\"Time_hr\"]).issubset(df.columns):\n",
        "    df[\"Energy_proxy\"] = df[\"Temperature_C\"] * df[\"Time_hr\"]\n",
        "\n",
        "# ---------- 9) SAVE CLEANED DATA ----------\n",
        "df.to_csv(SAVE_PATH, index=False)\n",
        "print(f\"[Save] Cleaned dataset -> {SAVE_PATH}\")\n",
        "print(f\"[Info] Final columns ({len(df.columns)}): {list(df.columns)}\")"
      ]
    },
