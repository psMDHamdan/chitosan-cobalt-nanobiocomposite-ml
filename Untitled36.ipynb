      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.preprocessing import MinMaxScaler\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "print(\"=\"*80)\n",
        "print(\"CORRECT PHYSICS-INFORMED DATA AUGMENTATION\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# ============================================================\n",
        "# 1. LOAD ORIGINAL DATA\n",
        "# ============================================================\n",
        "\n",
        "BASE_PATH = \"/content/data_with_antimicrobial_score.csv\" # Corrected file path\n",
        "df_original = pd.read_csv(BASE_PATH)\n",
        "n_original = len(df_original)\n",
        "\n",
        "print(f\"\\n\\u2713 Loaded {n_original} original samples\")\n",
        "\n",
        "# ============================================================\n",
        "# 2. SPLIT DATA BEFORE AUGMENTATION (CRITICAL!)\n",
        "# ============================================================\n",
        "\n",
        "# MUST split before augmentation to prevent data leakage\n",
        "train_df, test_df = train_test_split(\n",
        "    df_original,\n",
        "    test_size=0.2,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "print(f\"\\n\\u2713 Split into train ({len(train_df)}) and test ({len(test_df)})\")\n",
        "print(\"\\u26a0\\ufe0f  IMPORTANT: We will ONLY augment training data!\")\n",
        "\n",
        "# ============================================================\n",
        "# 3. DEFINE AUGMENTATION PARAMETERS\n",
        "# ============================================================\n",
        "\n",
        "# Only augment SYNTHESIS parameters, NOT physicochemical properties\n",
        "synthesis_params = [\n",
        "    \"Chitosan_Conc_mgmL\",\n",
        "    \"Chitosan_MW_kDa\",\n",
        "    \"Chitosan_DD_percent\",\n",
        "    \"Cobalt_Conc_mM\",\n",
        "    \"pH\",\n",
        "    \"Temperature_C\",\n",
        "    \"Time_hr\",\n",
        "    \"Stirring_Speed_rpm\",\n",
        "    \"Crosslinker_Conc_mM\",\n",
        "    \"Ionic_Strength_mM\"\n",
        "]\n",
        "\n",
        "# Physical bounds (literature-based)\n",
        "bounds = {\n",
        "    \"Chitosan_Conc_mgmL\": (0.5, 10),\n",
        "    \"Chitosan_MW_kDa\": (50, 500),\n",
        "    \"Chitosan_DD_percent\": (60, 95),\n",
        "    \"Cobalt_Conc_mM\": (0.1, 50),\n",
        "    \"pH\": (3, 7),\n",
        "    \"Temperature_C\": (20, 100),\n",
        "    \"Time_hr\": (0.1, 12),\n",
        "    \"Stirring_Speed_rpm\": (100, 1500),\n",
        "    \"Crosslinker_Conc_mM\": (0, 20),\n",
        "    \"Ionic_Strength_mM\": (1, 500)\n",
        "}\n",
        "\n",
        "# Realistic noise levels (based on experimental reproducibility)\n",
        "noise_std = {\n",
        "    \"Chitosan_Conc_mgmL\": 0.05,      # 5% CV typical\n",
        "    \"Chitosan_MW_kDa\": 0.08,         # MW has batch variation\n",
        "    \"Chitosan_DD_percent\": 0.03,     # Usually well-controlled\n",
        "    \"Cobalt_Conc_mM\": 0.05,          # Weighing precision\n",
        "    \"pH\": 0.02,                       # pH meter precision \\u00b10.02\n",
        "    \"Temperature_C\": 0.03,            # Temperature control\n",
        "    \"Time_hr\": 0.05,                  # Timing variation\n",
        "    \"Stirring_Speed_rpm\": 0.05,      # Motor stability\n",
        "    \"Crosslinker_Conc_mM\": 0.05,     # Pipetting error\n",
        "    \"Ionic_Strength_mM\": 0.08         # Solution preparation\n",
        "}\n",
        "\n",
        "# ============================================================\n",
        "# 4. PHYSICS-BASED FEASIBILITY CHECKER\n",
        "# ============================================================\n",
        "\n",
        "def is_feasible(row):\n",
        "    \"\"\"\n",
        "    Check if parameter combination is physically feasible\n",
        "    \"\"\"\n",
        "    # Rule 1: High MW requires lower concentration\n",
        "    if row[\"Chitosan_MW_kDa\"] > 300 and row[\"Chitosan_Conc_mgmL\"] > 5:\n",
        "        return False\n",
        "\n",
        "    # Rule 2: pH must allow chitosan solubility\n",
        "    if row[\"pH\"] > 6.5:\n",
        "        return False  # Chitosan precipitates\n",
        "\n",
        "    # Rule 3: Temperature-time not excessive\n",
        "    thermal_load = row[\"Temperature_C\"] * row[\"Time_hr\"]\n",
        "    if thermal_load > 600:  # Degradation threshold\n",
        "        return False\n",
        "\n",
        "    # Rule 4: Cobalt-to-chitosan ratio reasonable\n",
        "    co_cs_ratio = row[\"Cobalt_Conc_mM\"] / (row[\"Chitosan_Conc_mgmL\"] + 0.01)\n",
        "    if co_cs_ratio > 10 or co_cs_ratio < 0.1:\n",
        "        return False\n",
        "\n",
        "    return True\n",
        "\n",
        "# ============================================================\n",
        "# 5. CORRECT AUGMENTATION FUNCTION\n",
        "# ============================================================\n",
        "\n",
        "def augment_sample(row, synthesis_cols, bounds, noise_std, max_attempts=50):\n",
        "    \"\"\"\n",
        "    Augment a single sample by perturbing ONLY synthesis parameters\n",
        "    Keep physicochemical properties (Size, PDI, Zeta) UNCHANGED\n",
        "    \"\"\"\n",
        "    for attempt in range(max_attempts):\n",
        "        aug_row = row.copy()\n",
        "\n",
        "        # Add Gaussian noise to synthesis parameters only\n",
        "        for col in synthesis_cols:\n",
        "            if col in aug_row.index and col in noise_std:\n",
        "                current_val = aug_row[col]\n",
        "                sigma = noise_std[col] * current_val  # Relative noise\n",
        "\n",
        "                # Add noise\n",
        "                new_val = current_val + np.random.normal(0, sigma)\n",
        "\n",
        "                # Clip to physical bounds\n",
        "                if col in bounds:\n",
        "                    low, high = bounds[col]\n",
        "                    new_val = np.clip(new_val, low, high)\n",
        "\n",
        "                aug_row[col] = new_val\n",
        "\n",
        "        # Check if augmented parameters are feasible\n",
        "        if is_feasible(aug_row):\n",
        "            # CRITICAL: Keep physicochemical properties unchanged\n",
        "            # In reality, these would be measured AFTER synthesis\n",
        "            # Here we're creating synthetic \"what-if\" scenarios\n",
        "            return aug_row\n",
        "\n",
        "    # If can't generate feasible sample, return original\n",
        "    return row\n",
        "\n",
        "# ============================================================\n",
        "# 6. AUGMENT TRAINING DATA ONLY\n",
        "# ============================================================\n",
        "\n",
        "AUGMENTATION_FACTOR = 3  # Create 3 synthetic versions per real sample\n",
        "\n",
        "print(f\"\\n\" + \"=\"*80)\n",
        "print(f\"AUGMENTING TRAINING DATA ({AUGMENTATION_FACTOR}\\u00d7 multiplier)\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "augmented_samples = []\n",
        "\n",
        "# Keep original training data\n",
        "for idx, row in train_df.iterrows():\n",
        "    row_dict = row.to_dict()\n",
        "    row_dict['aug_round'] = 0\n",
        "    row_dict['is_original'] = True\n",
        "    augmented_samples.append(row_dict)\n",
        "\n",
        "# Create augmented versions\n",
        "for aug_round in range(1, AUGMENTATION_FACTOR + 1):\n",
        "    print(f\"\\nAugmentation round {aug_round}/{AUGMENTATION_FACTOR}...\")\n",
        "\n",
        "    for idx, row in train_df.iterrows():\n",
        "        # Augment synthesis parameters only\n",
        "        aug_row = augment_sample(\n",
        "            row,\n",
        "            synthesis_params,\n",
        "            bounds,\n",
        "            noise_std\n",
        "        )\n",
        "\n",
        "        aug_dict = aug_row.to_dict()\n",
        "        aug_dict['aug_round'] = aug_round\n",
        "        aug_dict['is_original'] = False\n",
        "        augmented_samples.append(aug_dict)\n",
        "\n",
        "# Create augmented training dataframe\n",
        "train_augmented = pd.DataFrame(augmented_samples)\n",
        "\n",
        "print(f\"\\n\\u2713 Created {len(train_augmented)} training samples:\")\n",
        "print(f\"  - Original: {len(train_df)}\")\n",
        "print(f\"  - Synthetic: {len(train_augmented) - len(train_df)}\")\n",
        "\n",
        "# ============================================================\n",
        "# 7. RECALCULATE DERIVED FEATURES (Consistency)\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"RECALCULATING DERIVED FEATURES\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "pKa = 6.3\n",
        "\n",
        "for df_part in [train_augmented, test_df]:\n",
        "    # Ensure these columns exist and recalculate\n",
        "    if all(c in df_part.columns for c in [\"Cobalt_Conc_mM\",\"Chitosan_Conc_mgmL\"]):\n",
        "        df_part[\"Co_to_CS_ratio\"] = df_part[\"Cobalt_Conc_mM\"] / (df_part[\"Chitosan_Conc_mgmL\"] + 1e-9)\n",
        "\n",
        "    if all(c in df_part.columns for c in [\"Chitosan_DD_percent\",\"pH\"]):\n",
        "        protonation = 1 / (1 + 10 ** (df_part[\"pH\"] - pKa))\n",
        "        df_part[\"CS_charge_index\"] = df_part[\"Chitosan_DD_percent\"] * protonation\n",
        "\n",
        "    if \"pH\" in df_part.columns:\n",
        "        df_part[\"pHpKa_diff\"] = df_part[\"pH\"] - pKa\n",
        "\n",
        "    if all(c in df_part.columns for c in [\"Temperature_C\",\"Time_hr\"]):\n",
        "        df_part[\"Energy_proxy\"] = df_part[\"Temperature_C\"] * df_part[\"Time_hr\"]\n",
        "\n",
        "print(\"\\u2713 Derived features recalculated\")\n",
        "\n",
        "# ============================================================\n",
        "# 8. VALIDATION: COMPARE DISTRIBUTIONS\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"VALIDATION: DISTRIBUTION COMPARISON\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "fig, axes = plt.subplots(3, 4, figsize=(16, 12))\n",
        "axes = axes.flatten()\n",
        "\n",
        "# Compare distributions of synthesis parameters\n",
        "for idx, col in enumerate(synthesis_params):\n",
        "    if idx < len(axes):\n",
        "        ax = axes[idx]\n",
        "\n",
        "        # Original training data\n",
        "        original_data = train_df[col].values\n",
        "\n",
        "        # Augmented training data (synthetic only)\n",
        "        synthetic_data = train_augmented[train_augmented['aug_round'] > 0][col].values\n",
        "\n",
        "        # Plot\n",
        "        ax.hist(original_data, bins=20, alpha=0.6, label='Original', density=True)\n",
        "        ax.hist(synthetic_data, bins=20, alpha=0.6, label='Augmented', density=True)\n",
        "        ax.set_title(col, fontsize=10)\n",
        "        ax.legend(fontsize=8)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"augmentation_validation.png\", dpi=300, bbox_inches='tight')\n",
        "plt.show()\n",
        "\n",
        "print(\"\\u2713 Distribution plots saved: augmentation_validation.png\")\n",
        "\n",
        "# ============================================================\n",
        "# 9. CRITICAL CHECK: TARGET DISTRIBUTION\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"CRITICAL CHECK: TARGET VARIABLE\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "if \"Antimicrobial_Score\" in train_augmented.columns:\n",
        "    original_targets = train_df[\"Antimicrobial_Score\"].values\n",
        "    augmented_targets = train_augmented[\"Antimicrobial_Score\"].values\n",
        "\n",
        "    print(f\"\\nOriginal target statistics:\")\n",
        "    print(f\"  Mean: {original_targets.mean():.4f}\")\n",
        "    print(f\"  Std:  {original_targets.std():.4f}\")\n",
        "    print(f\"  Range: [{original_targets.min():.4f}, {original_targets.max():.4f}]\")\n",
        "\n",
        "    print(f\"\\nAugmented target statistics:\")\n",
        "    print(f\"  Mean: {augmented_targets.mean():.4f}\")\n",
        "    print(f\"  Std:  {augmented_targets.std():.4f}\")\n",
        "    print(f\"  Range: [{augmented_targets.min():.4f}, {augmented_targets.max():.4f}]\")\n",
        "\n",
        "    # Plot target distribution\n",
        "    plt.figure(figsize=(10, 4))\n",
        "\n",
        "    plt.subplot(1, 2, 1)\n",
        "    plt.hist(original_targets, bins=30, alpha=0.7, edgecolor='black')\n",
        "    plt.title(\"Original Target Distribution\")\n",
        "    plt.xlabel(\"Antimicrobial Score\")\n",
        "    plt.ylabel(\"Frequency\")\n",
        "\n",
        "    plt.subplot(1, 2, 2)\n",
        "    plt.hist(augmented_targets, bins=30, alpha=0.7, edgecolor='black', color='orange')\n",
        "    plt.title(\"Augmented Target Distribution\")\n",
        "    plt.xlabel(\"Antimicrobial Score\")\n",
        "    plt.ylabel(\"Frequency\")\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(\"target_distribution_check.png\", dpi=300, bbox_inches='tight')\n",
        "    plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# 10. SAVE DATASETS\n",
        "# ============================================================\n",
        "\n",
        "TRAIN_AUG_PATH = \"/content/train_augmented.csv\"\n",
        "TEST_PATH = \"/content/test_original.csv\"\n",
        "\n",
        "train_augmented.to_csv(TRAIN_AUG_PATH, index=False)\n",
        "test_df.to_csv(TEST_PATH, index=False)\n",
        "\n",
        "print(f\"\\n\\u2713 Saved augmented training data: {TRAIN_AUG_PATH}\")\n",
        "print(f\"\\u2713 Saved test data (original only): {TEST_PATH}\")\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"\\u2705 AUGMENTATION COMPLETE\")\n",
        "print(\"=\"*80)"
      ],
