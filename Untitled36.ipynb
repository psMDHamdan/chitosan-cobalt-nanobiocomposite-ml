      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.model_selection import KFold, GroupKFold, cross_val_score\n",
        "from sklearn.preprocessing import StandardScaler, RobustScaler\n",
        "from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor\n",
        "from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score\n",
        "from xgboost import XGBRegressor\n",
        "import joblib\n",
        "import warnings\n",
        "\n",
        "# Suppress warnings for cleaner output\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "print(\"=\"*100)\n",
        "print(\"🧪 SCIENTIFICALLY RIGOROUS ML TRAINING (PUBLICATION READY)\")\n",
        "print(\"=\"*100)\n",
        "\n",
        "# ============================================================\n",
        "# 1. LOAD DATA & ROBUST PREPROCESSING\n",
        "# ============================================================\n",
        "\n",
        "# Load the file\n",
        "df = pd.read_csv(\"train_augmented.csv\")\n",
        "print(f\"\\n✓ Loaded Dataset: {df.shape}\")\n",
        "\n",
        "# Handle Augmentation Tracking\n",
        "if \"aug_round\" not in df.columns:\n",
        "    df[\"aug_round\"] = 0\n",
        "    df[\"sample_id\"] = np.arange(len(df))\n",
        "else:\n",
        "    # Reconstruct sample_id logic if missing\n",
        "    if \"sample_id\" not in df.columns:\n",
        "        n_original = (df[\"aug_round\"] == 0).sum()\n",
        "        n_aug = len(df) // n_original\n",
        "        df[\"sample_id\"] = np.repeat(np.arange(n_original), n_aug)\n",
        "\n",
        "# Define Features and Target\n",
        "target_col = \"Antimicrobial_Score\"\n",
        "exclude_cols = [\n",
        "    target_col, \"Particle_Size_nm\", \"PDI\", \"Zeta_Potential_mV\",\n",
        "    \"aug_round\", \"sample_id\", \"norm_Particle_Size_nm\"\n",
        "]\n",
        "\n",
        "X_cols = [c for c in df.columns if c not in exclude_cols]\n",
        "X = df[X_cols].values\n",
        "y = df[target_col].values\n",
        "groups = df[\"sample_id\"].values\n",
        "\n",
        "print(f\"✓ Feature Count: {len(X_cols)}\")\n",
        "print(f\"✓ Target Variable: {target_col}\")\n",
        "\n",
        "# ============================================================\n",
        "# 2. STRICT TRAIN/TEST SPLIT (PREVENT DATA LEAKAGE)\n",
        "# ============================================================\n",
        "\n",
        "# We split by UNIQUE SAMPLE ID, not by row.\n",
        "# This ensures all augmented versions of Sample #5 stay together.\n",
        "unique_groups = np.unique(groups)\n",
        "np.random.seed(42)\n",
        "\n",
        "# 20% held out for final testing\n",
        "test_groups = np.random.choice(unique_groups, size=int(0.2 * len(unique_groups)), replace=False)\n",
        "train_groups = np.setdiff1d(unique_groups, test_groups)\n",
        "\n",
        "train_mask = np.isin(groups, train_groups)\n",
        "test_mask = np.isin(groups, test_groups)\n",
        "\n",
        "X_train, y_train = X[train_mask], y[train_mask]\n",
        "X_test, y_test = X[test_mask], y[test_mask]\n",
        "groups_train = groups[train_mask]\n",
        "\n",
        "# Identify \"Original\" (Real) samples in Test Set for final validation\n",
        "test_original_mask = (df.iloc[test_mask][\"aug_round\"] == 0).values\n",
        "X_test_real = X_test[test_original_mask]\n",
        "y_test_real = y_test[test_original_mask]\n",
        "\n",
        "print(f\"\\n✓ Training Set: {len(X_train)} rows ({len(train_groups)} unique formulations)\")\n",
        "print(f\"✓ Test Set:     {len(X_test)} rows ({len(test_groups)} unique formulations)\")\n",
        "print(f\"✓ REAL Test Data: {len(X_test_real)} samples (The Gold Standard)\")\n",
        "\n",
        "# Scaling (RobustScaler handles outliers better than Standard)\n",
        "scaler = RobustScaler()\n",
        "X_train_scaled = scaler.fit_transform(X_train)\n",
        "X_test_scaled = scaler.transform(X_test)\n",
        "X_test_real_scaled = scaler.transform(X_test_real)\n",
        "\n",
        "# ============================================================\n",
        "# 3. DEFINE REGULARIZED MODELS (PREVENT OVERFITTING)\n",
        "# ============================================================\n",
        "\n",
        "# We add constraints (max_depth, subsample) to stop the model from memorizing noise.\n",
        "models = {\n",
        "    \"Random Forest\": RandomForestRegressor(\n",
        "        n_estimators=200,\n",
        "        max_depth=7,            # Restricted depth\n",
        "        min_samples_leaf=3,     # Requires more samples per leaf\n",
        "        max_features=\"sqrt\",    # Decorrelates trees\n",
        "        random_state=42,\n",
        "        n_jobs=-1\n",
        "    ),\n",
        "    \"XGBoost\": XGBRegressor(\n",
        "        n_estimators=150,\n",
        "        max_depth=4,            # Shallow trees\n",
        "        learning_rate=0.03,     # Slower learning\n",
        "        subsample=0.7,          # Uses only 70% of data per tree\n",
        "        colsample_bytree=0.7,   # Uses only 70% of features per tree\n",
        "        random_state=42,\n",
        "        n_jobs=-1\n",
        "    ),\n",
        "    \"Gradient Boosting\": GradientBoostingRegressor(\n",
        "        n_estimators=150,\n",
        "        max_depth=3,\n",
        "        learning_rate=0.05,\n",
        "        subsample=0.8,\n",
        "        random_state=42\n",
        "    )\n",
        "}\n",
        "\n",
        "# ============================================================\n",
        "# 4. TRAINING WITH GROUPED CROSS-VALIDATION\n",
        "# ============================================================\n",
        "\n",
        "results = []\n",
        "print(\"\\n\" + \"-\"*80)\n",
        "print(\"TRAINING PROGRESS\")\n",
        "print(\"-\" * 80)\n",
        "\n",
        "best_model = None\n",
        "best_r2 = -np.inf\n",
        "best_name = \"\"\n",
        "\n",
        "# GroupKFold ensures validation folds never see training data from the same synthesis batch\n",
        "cv = GroupKFold(n_splits=5)\n",
        "\n",
        "for name, model in models.items():\n",
        "    # 1. Cross-Validation Score\n",
        "    cv_scores = []\n",
        "    for train_idx, val_idx in cv.split(X_train_scaled, y_train, groups=groups_train):\n",
        "        model.fit(X_train_scaled[train_idx], y_train[train_idx])\n",
        "        score = model.score(X_train_scaled[val_idx], y_train[val_idx])\n",
        "        cv_scores.append(score)\n",
        "\n",
        "    cv_mean = np.mean(cv_scores)\n",
        "\n",
        "    # 2. Final Fit on full training data\n",
        "    model.fit(X_train_scaled, y_train)\n",
        "\n",
        "    # 3. Evaluate on REAL Test Data (Original samples only)\n",
        "    y_pred_real = model.predict(X_test_real_scaled)\n",
        "\n",
        "    r2_real = r2_score(y_test_real, y_pred_real)\n",
        "    rmse_real = np.sqrt(mean_squared_error(y_test_real, y_pred_real))\n",
        "    mae_real = mean_absolute_error(y_test_real, y_pred_real)\n",
        "\n",
        "    # Check for overfitting gap\n",
        "    train_score = model.score(X_train_scaled, y_train)\n",
        "    gap = train_score - r2_real\n",
        "\n",
        "    print(f\"▶ {name:18s} | CV R²: {cv_mean:.3f} | Test R² (Real): {r2_real:.3f} | Gap: {gap:.3f}\")\n",
        "\n",
        "    results.append({\n",
        "        \"Model\": name,\n",
        "        \"CV_R2\": cv_mean,\n",
        "        \"Test_R2_Real\": r2_real,\n",
        "        \"RMSE\": rmse_real,\n",
        "        \"Gap\": gap\n",
        "    })\n",
        "\n",
        "    if r2_real > best_r2:\n",
        "        best_r2 = r2_real\n",
        "        best_model = model\n",
        "        best_name = name\n",
        "\n",
        "# ============================================================\n",
        "# 5. FINAL EVALUATION & SAVING\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(f\"🏆 BEST MODEL SELECTED: {best_name}\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "results_df = pd.DataFrame(results).sort_values(by=\"Test_R2_Real\", ascending=False)\n",
        "print(results_df)\n",
        "\n",
        "# Plotting Predictions vs Reality for the Best Model\n",
        "y_pred_final = best_model.predict(X_test_real_scaled)\n",
        "\n",
        "plt.figure(figsize=(8, 6))\n",
        "plt.scatter(y_test_real, y_pred_final, color='teal', alpha=0.7, s=80, edgecolors='k')\n",
        "plt.plot([0, 1], [0, 1], 'r--', lw=2)  # Ideal line\n",
        "plt.xlabel(\"Actual Antimicrobial Score (Lab Data)\")\n",
        "plt.ylabel(\"Predicted Score (ML Model)\")\n",
        "plt.title(f\"Prediction Accuracy: {best_name}\\nR² = {best_r2:.3f}\")\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"final_model_validation.png\", dpi=300)\n",
        "print(\"\\n✓ Saved validation plot: final_model_validation.png\")\n",
        "\n",
        "# Save Artifacts\n",
        "joblib.dump(best_model, \"best_model_corrected.joblib\")\n",
        "joblib.dump(scaler, \"feature_scaler.joblib\")\n",
        "joblib.dump(X_cols, \"feature_columns.pkl\")\n",
        "print(\"✓ Saved Best Model & Scaler for Virtual Chemist step.\")\n",
        "\n",
        "print(\"\\n🚀 READY. You can now run the 'Virtual Chemist' prediction code.\")"
      ],
